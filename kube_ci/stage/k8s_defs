#!/bin/bash
# Параметры кластера окружения STAGE. Подгружается из точек входа (source).
# Идемпотентен.
#
# ВРЕМЕННО: dev/stage/prod пока указывают на один физический preprod-кластер
# (там же крутится preprod cmdb). Различаются только ENVNAME (неймспейс из
# .helm/def.sh продукта). Когда появится отдельный stage-кластер -- заменить
# KUBECONTEXT/REGISTRY/NODE_IP ниже. Все значения переопределяются env-переменными.

NODE_IP=${K8S_NODE_IP:-192.168.125.31}

REGISTRY=${REGISTRY:-registry-${NODE_IP}.nip.io}
KUBECONTEXT=${KUBECONTEXT:-k8sadmin-k8s-alt-paas@service-k8s-alt-paas}
KUBECONFIG=${KUBECONFIG:-~/.kube/config}

kubectl config use-context "$KUBECONTEXT"

# Ingress-nginx отдаёт self-signed HTTPS; принуждаем werf на HTTP + skip verify
# через env vars (cli-флаги до stage-storage не доходят).
export WERF_INSECURE_REGISTRY=true
export WERF_SKIP_TLS_VERIFY_REGISTRY=true
