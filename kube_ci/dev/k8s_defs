#!/bin/bash
# Параметры кластера окружения DEV. Подгружается из точек входа (source).
# Идемпотентен.
#
# Кластер окружения (внутренняя сеть с NAT/интернетом -- чтобы dev-под
# клонировал монорепо с github). Различаются только ENVNAME (неймспейс из
# .helm/def.sh). Значения переопределяются env-переменными.

NODE_IP=${K8S_NODE_IP:-192.168.123.31}

REGISTRY=${REGISTRY:-registry-${NODE_IP}.nip.io}
KUBECONTEXT=${KUBECONTEXT:-k8sadmin-k8s-public-paas@service-k8s-public-paas}
KUBECONFIG=${KUBECONFIG:-~/.kube/config}

kubectl config use-context "$KUBECONTEXT"

# Ingress-nginx отдаёт self-signed HTTPS; принуждаем werf на HTTP + skip verify
# через env vars (cli-флаги до stage-storage не доходят).
export WERF_INSECURE_REGISTRY=true
export WERF_SKIP_TLS_VERIFY_REGISTRY=true
