# Шаблон. Скопируйте в ./productlist и при необходимости отредактируйте.
# Формат: [<product>]=<env>, где <product> -- каталог в ../../apps,
# а <env> -- имя shell-функции в .helm/def.sh продукта (здесь -- dev).

#!/bin/bash

declare -A PRODUCTS

PRODUCTS=(
    [app1-java-react]=dev
    [app2-python-angular]=dev
)
