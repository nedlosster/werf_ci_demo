# окружения kube_ci: продукты подтягиваются локально, конфиг -- локальный
kube_ci/*/products
kube_ci/*/products/*
kube_ci/*/productlist
*.log
/CLAUDE.md
/.claude/


# werf: локальные build-артефакты (но НЕ .werf-partial/ -- это исходник)
.werf/

# build-артефакты продуктов (maven/node/python) -- создаются при сборке и
# dev-start внутри пода; в git не нужны, держат /workspace-клон чистым.
apps/**/target/
apps/**/node_modules/
apps/**/dist/
apps/**/.angular/
apps/**/__pycache__/
apps/**/*.egg-info/
apps/*/frontend/package-lock.json

# ssh-ключи dev-схемы (кладёт оператор)
apps/*/.helm/tmp/

# werf-секреты: ключ и plaintext-копии (зашифрованные secrets-<env>.yaml -- в git)
.werf_secret_key
apps/*/.werf_secret_key
apps/*/.helm/secret-values.yaml
apps/*/.helm/secrets/values.yaml

# артефакты генерации (диаграммы рендерятся, PDF собираются по запросу)
docs/pdf/

# внутренние журналы планирования (не для публичного репозитория)
docs/todo/

# IDE / ОС
.idea/
.vscode/
*.swp
.DS_Store
