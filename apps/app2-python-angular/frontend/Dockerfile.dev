# syntax=docker/dockerfile:1
# dev-образ фронтенда app2-python-angular: полный node + Angular CLI, спит в кластере.
# Исходники клонируются в /workspace (PVC); кеш npm и .vscode-server через
# симлинки в /home/app/homeapp (PVC). Контекст сборки -- корень продукта.
FROM node:20-bookworm

# Локаль и таймзона: иначе LC_ALL даёт warning, время в логах -- UTC.
ENV LANG=en_US.UTF-8 \
    LC_ALL=en_US.UTF-8 \
    TZ=Europe/Moscow \
    TERM=xterm

# git/ssh/sudo -- база; остальное -- утилиты для разработки и отладки внутри пода.
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        git openssh-client sudo procps ca-certificates \
        locales tzdata mc curl wget less jq vim \
        iputils-ping dnsutils net-tools telnet socat zip tree postgresql-client && \
    sed -i 's/^# *en_US.UTF-8/en_US.UTF-8/' /etc/locale.gen && locale-gen && \
    ln -snf /usr/share/zoneinfo/Europe/Moscow /etc/localtime && echo "Europe/Moscow" > /etc/timezone && \
    rm -rf /var/lib/apt/lists/*

RUN useradd -m -u 10001 -s /bin/bash app && \
    echo "app ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/app && chmod 0440 /etc/sudoers.d/app

# git pull по SSH из пода: ключ монтируется в ~/.ssh/id_rsa, host-проверку
# github.com отключаем глобально -- pull от пользователя app идёт без known_hosts.
RUN printf 'Host github.com\n\tStrictHostKeyChecking no\n\tUserKnownHostsFile=/dev/null\n' >> /etc/ssh/ssh_config

USER app
WORKDIR /home/app

RUN mkdir -p /home/app/homeapp/.npm /home/app/homeapp/.cache /home/app/homeapp/.vscode-server /home/app/homeapp/.config && \
    ln -sfn /home/app/homeapp/.npm /home/app/.npm && \
    ln -sfn /home/app/homeapp/.cache /home/app/.cache && \
    ln -sfn /home/app/homeapp/.vscode-server /home/app/.vscode-server && \
    ln -sfn /home/app/homeapp/.config /home/app/.config

COPY --chown=app:app install/prepare-scripts /home/app/prepare-scripts

EXPOSE 8080
ENTRYPOINT ["/bin/sleep", "infinity"]
