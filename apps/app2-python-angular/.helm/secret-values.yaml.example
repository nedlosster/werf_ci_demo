# Шаблон секретов werf для app2-python-angular. Использование:
#   1. cp .helm/secret-values.yaml.example .helm/secrets/values.yaml
#   2. заменить CHANGE_ME на реальные значения
#   3. зашифровать: cd .helm/secrets && ./encrypt.sh dev   (или prod)
#      -> .helm/secrets-dev.yaml (зашифрован, коммитится)
#   4. werf converge сам подхватит .helm/secrets-<env>.yaml через --secret-values.
# Ключ шифрования: WERF_SECRET_KEY | .werf_secret_key | ~/.werf/global_secret_key.
#
# Если secrets-<env>.yaml не задан -- чарт использует демо-дефолты из values.yaml.

secrets:
  dbPassword: "CHANGE_ME_DB"
  pgadminEmail: "app2-admin@example.com"
  pgadminPassword: "CHANGE_ME_PGADMIN"
